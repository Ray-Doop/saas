        </dependency>
        <dependency>
            <groupId>com.skynet</groupId>
            <artifactId>sky-net-common-security</artifactId>
        </dependency>
        <dependency>
            <groupId>com.skynet</groupId>
            <artifactId>sky-net-common-mybatis</artifactId>
