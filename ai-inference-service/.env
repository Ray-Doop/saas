# 智绘云 AI推理服务 环境配置
APP_NAME=ai-inference-service
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ComfyUI
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WS_URL=ws://127.0.0.1:8188/ws
COMFYUI_TIMEOUT=300

# RocketMQ
ROCKETMQ_NAME_SERVER=127.0.0.1:9876
ROCKETMQ_CONSUMER_GROUP=ai-inference-consumer-group
ROCKETMQ_TOPIC=ai-gen-task-topic
ROCKETMQ_TAG=gen_task

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-results
MINIO_SECURE=false

# 回调
CALLBACK_TOPIC=ai-gen-result-topic
CALLBACK_TAG=gen_result

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=text
